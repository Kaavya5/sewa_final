# SEWA Environment Configuration
# Copy this file to .env and fill in your credentials

# LLM API Configuration (choose one)
# ==========================================

# Together AI (Recommended)
# Get your key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# Groq (Fast inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (Multiple models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# LLM Model Selection
# ==========================================
LLM_PROVIDER=together  # Options: together, groq, openrouter
LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# SEWA Configuration
# ==========================================
SEWA_ALERT_INTERVAL_MIN=15  # Alert evaluation frequency
SEWA_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
SEWA_ENABLE_LLM_EXPLANATIONS=true  # Set to false to disable LLM calls

# Data Paths
# ==========================================
SEWA_DATA_DIR=./data
SEWA_MODEL_DIR=./models
SEWA_LOG_DIR=./logs